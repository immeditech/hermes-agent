# Kopiere diese Datei nach .devcontainer/.env und fülle die Werte aus.
# .env ist gitignored und wird vom docker-compose.yaml (env_file) geladen.

# --- Git-Identität im Container (für Commits aus dem Devcontainer) ---
GIT_USER_NAME=Dein Name
GIT_USER_EMAIL=dein.name@immeditech.ch

# --- LLM-Provider (mindestens einen setzen) ---
# Siehe `hermes model` / README für unterstützte Provider.
OPENROUTER_API_KEY=
OPENAI_API_KEY=
NOUS_API_KEY=
ANTHROPIC_API_KEY=

# --- Gitea (optional) ---
GITEA_ACCESS_TOKEN=
